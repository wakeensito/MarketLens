#!/usr/bin/env bash
#
# bin/deploy — Safe `sam deploy` wrapper.
#
# Why this exists:
#   The SAM template requires GoogleClientId / GoogleClientSecret for the
#   Cognito Google identity provider. CloudFormation does NOT support
#   `{{resolve:ssm-secure:...}}` references for Cognito IdP properties, so
#   the secrets can't be auto-resolved from the template. This script reads
#   them from SSM at deploy time and passes them via `--parameter-overrides`.
#
# Safe usage:
#   - For routine deploys after the secrets are already in CloudFormation:
#     a bare `sam deploy` works — samconfig.toml omits the secrets, so
#     CloudFormation preserves the existing values. Fail-safe.
#   - For FRESH stack creation OR after rotating Google credentials in SSM:
#     run `bin/deploy` so the new values are pushed into CloudFormation.
#
# Optional positional arg: stage name. Defaults to `dev`.

set -euo pipefail

STAGE="${1:-dev}"
SSM_PREFIX="/marketlens/${STAGE}"

echo "→ Fetching Google OAuth credentials from SSM (${SSM_PREFIX}/google-client-*)..."
GOOGLE_CLIENT_ID=$(aws ssm get-parameter \
    --name "${SSM_PREFIX}/google-client-id" \
    --with-decryption \
    --query 'Parameter.Value' \
    --output text)
GOOGLE_CLIENT_SECRET=$(aws ssm get-parameter \
    --name "${SSM_PREFIX}/google-client-secret" \
    --with-decryption \
    --query 'Parameter.Value' \
    --output text)

if [[ -z "${GOOGLE_CLIENT_ID}" || -z "${GOOGLE_CLIENT_SECRET}" ]]; then
    echo "✗ Empty SSM value(s) — refusing to deploy." >&2
    exit 1
fi

echo "→ sam build..."
sam build

echo "→ sam deploy (stage: ${STAGE})..."
sam deploy --no-confirm-changeset --no-fail-on-empty-changeset \
    --parameter-overrides \
        "Stage=${STAGE}" \
        "CognitoCallbackDomain=plinths.net" \
        "GoogleClientId=${GOOGLE_CLIENT_ID}" \
        "GoogleClientSecret=${GOOGLE_CLIENT_SECRET}"
