              <mxPoint x="320" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge-9-label" value="GET/DELETE /api/muse/conversations/{id}" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=none;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;" connectable="0" vertex="1" parent="edge-9">
          <mxGeometry x="0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Edge 10: API Gateway → Authorizer Lambda -->
        <mxCell id="edge-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="grp-apigw" target="grp-authorizer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge 11: Authorizer → Muse Sync Lambda -->
        <mxCell id="edge-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="grp-authorizer" target="grp-sync-lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge 12: Muse Sync Lambda → Conversations Table -->
        <mxCell id="edge-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="grp-sync-lambda" target="grp-ddb-conv">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="680" />
              <mxPoint x="820" y="400" />
              <mxPoint x="920" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══ STEP BADGES (on-diagram) ═══ -->

        <mxCell id="step-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="1" vertex="1" parent="1">
          <mxGeometry x="190" y="455" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="2" vertex="1" parent="1">
          <mxGeometry x="395" y="295" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="3" vertex="1" parent="1">
          <mxGeometry x="595" y="295" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="4" vertex="1" parent="1">
          <mxGeometry x="595" y="455" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="5" vertex="1" parent="1">
          <mxGeometry x="795" y="295" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="6" vertex="1" parent="1">
          <mxGeometry x="995" y="295" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="step-7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="7" vertex="1" parent="1">
          <mxGeometry x="395" y="655" width="28" height="28" as="geometry" />
        </mxCell>

        <!-- ═══ RIGHT SIDEBAR LEGEND ═══ -->
        <mxCell id="legend-bg" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor2=none;strokeWidth=1;size=20;indent=5;fillColor=light-dark(#EDF3FF,#305363);strokeColor=#6c8ebf;" value="" vertex="1" parent="1">
          <mxGeometry x="1500" y="30" width="650" height="970" as="geometry" />
        </mxCell>

        <mxCell id="legend-container" connectable="0" style="group" value="" vertex="1" parent="1">
          <mxGeometry x="1520" y="60" width="610" height="930" as="geometry" />
        </mxCell>

        <mxCell id="legend-title" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=18;fontStyle=1;fontFamily=Helvetica;" value="Data flow" vertex="1" parent="legend-container">
          <mxGeometry width="500" height="28" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="step-1-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="50" width="600" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step-1-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="1" vertex="1" parent="step-1-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-1-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Browser submits a chat turn&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;POST to &lt;code&gt;/api/muse/stream&lt;/code&gt; with HttpOnly auth cookie. Frontend reads the response as text/event-stream.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-1-legend">
          <mxGeometry x="52" width="548" height="90" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="step-2-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="160" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step-2-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="step-2-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-2-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;CloudFront routes to the streaming origin&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;A dedicated CF behavior &lt;code&gt;/api/muse/stream*&lt;/code&gt; forwards the request to a Lambda Function URL via OAC. The URL is configured with &lt;code&gt;InvokeMode: RESPONSE_STREAM&lt;/code&gt; so tokens flow without buffering.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-2-legend">
          <mxGeometry x="52" width="548" height="100" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step-3-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="280" width="600" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step-3-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="3" vertex="1" parent="step-3-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-3-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Stream Lambda verifies the cookie JWT&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Function URL auth is NONE; the Lambda itself validates the JWT against Cognito JWKs (shared module with the existing authorizer). Always-Deny on uncertainty.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-3-legend">
          <mxGeometry x="52" width="548" height="90" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="step-4-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="390" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step-4-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="4" vertex="1" parent="step-4-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-4-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Optional: fetch Max-tier provider keys&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;If the Max user selected OpenAI / Google AI / Perplexity, the Lambda reads the SecureString param at cold start and caches it globally. Pro users skip this hop — Bedrock only.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-4-legend">
          <mxGeometry x="52" width="548" height="100" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="step-5-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="510" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step-5-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="5" vertex="1" parent="step-5-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-5-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Load context from DynamoDB&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Reads the report&#39;s &lt;code&gt;result_json&lt;/code&gt; from the existing Reports table and the last N turns from the new Conversations table (GSI on &lt;code&gt;org_id&lt;/code&gt; for Max cross-report memory).&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-5-legend">
          <mxGeometry x="52" width="548" height="100" as="geometry" />
        </mxCell>

        <!-- Step 6 -->
        <mxCell id="step-6-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="630" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step-6-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="6" vertex="1" parent="step-6-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-6-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Bedrock streams tokens back as SSE&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;Lambda calls &lt;code&gt;InvokeModelWithResponseStream&lt;/code&gt; (Claude Haiku for Pro). Each delta is rewritten as an SSE &lt;code&gt;token&lt;/code&gt; event; sentence-final punctuation emits a &lt;code&gt;sentence_boundary&lt;/code&gt; event so the UI can do the 60ms settle pause.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-6-legend">
          <mxGeometry x="52" width="548" height="100" as="geometry" />
        </mxCell>

        <!-- Step 7 -->
        <mxCell id="step-7-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="750" width="600" height="110" as="geometry" />
        </mxCell>
        <mxCell id="step-7-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="7" vertex="1" parent="step-7-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-7-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Sync path (REST) for thread list and delete&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt; &lt;/b&gt;GET/DELETE &lt;code&gt;/api/muse/conversations/{report_id}&lt;/code&gt; uses the existing REST API Gateway + cookie Authorizer + a separate Muse Sync Lambda. No streaming needed for these ops.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-7-legend">
          <mxGeometry x="52" width="548" height="110" as="geometry" />
        </mxCell>

        <!-- Aux services note -->
        <mxCell id="aux-note" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=11;fontStyle=2;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#666666;" value="Auxiliary: CloudWatch logs every Lambda + API Gateway access log. IAM enforces scoped policies (no wildcard resources)." vertex="1" parent="legend-container">
          <mxGeometry y="880" width="600" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
