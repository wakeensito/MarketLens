        <mxCell id="edge-8-label" value="read report context" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=none;fontSize=11;fontFamily=Helvetica;" connectable="0" vertex="1" parent="edge-8">
          <mxGeometry x="0.4" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Sync path edges -->

        <!-- Edge 9: Browser → CloudFront → API Gateway (sync) — implied second branch. Edge from CloudFront down to API GW -->
        <mxCell id="edge-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;endArrow=classic;endFill=1;strokeColor=#8C4FFF;" edge="1" parent="1" source="grp-cloudfront" target="grp-apigw">
          <mxGeometry relative="1" as="geometry">
